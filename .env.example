# =============================================================
# AuditaSEO - Variables de entorno
# =============================================================
# Copia este archivo como .env.local y completa los valores

# --- Base de datos (PostgreSQL) ---
# Recomendado: Supabase (supabase.com) o Neon.tech - plan gratuito
DATABASE_URL="postgresql://user:password@host:5432/auditaseo"

# --- Redis (para BullMQ) ---
# Recomendado: Upstash (upstash.com) - plan gratuito
REDIS_URL="redis://user:password@host:6379"

# --- DeepSeek API ---
# Obtenla en: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-..."

# --- Serper.dev (Google Search API) ---
# Obtenla en: https://serper.dev - 2500 consultas/mes gratis
SERPER_API_KEY="..."

# --- Google PageSpeed Insights API ---
# Obtenla en: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY="..."

# --- Resend (emails transaccionales) ---
# Obtenla en: https://resend.com - 100 emails/día gratis
RESEND_API_KEY="re_..."

# --- Email del remitente ---
EMAIL_FROM="AuditaSEO <hola@tudominio.com>"

# --- Admin Panel ---
ADMIN_USER="admin"
ADMIN_PASSWORD="TuPasswordSegura123"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/tu-usuario/consultoria-seo"

# --- MultiSEO (opcional) ---
MULTISEO_API_URL=""
MULTISEO_API_KEY=""
